{
  "projects": [
    {
      "id": "${YOUR_BITWARDEN_SM_PROJECT_ID}",
      "name": "${YOUR_BITWARDEN_SM_PROJECT_NAME}"
    }
  ],
  "secrets": [
    {
      "key": "AVANTE_OPENAI_API_KEY",
      "value": "${YOUR_AVANTE_OPENAI_API_KEY}",
      "note": "OpenAI API key for Avante NeoVim plugin",
      "id": "00000000-0000-0000-0000-000000000001",
      "projectIds": []
    },
    {
      "key": "AVANTE_MOONSHOT_API_KEY",
      "value": "${YOUR_MOONSHOT_API_KEY}",
      "note": "Moonshot API key for Avante NeoVim plugin",
      "id": "00000000-0000-0000-0000-000000000002",
      "projectIds": []
    },
    {
      "key": "BW_CLIENTID",
      "value": "${YOUR_BITWARDEN_CLIENT_ID}",
      "note": "Bitwarden API client ID for --apikey login",
      "id": "00000000-0000-0000-0000-000000000003",
      "projectIds": []
    },
    {
      "key": "BW_CLIENTSECRET",
      "value": "${YOUR_BITWARDEN_CLIENT_SECRET}",
      "note": "Bitwarden API client secret for --apikey login",
      "id": "00000000-0000-0000-0000-000000000004",
      "projectIds": []
    },
    {
      "key": "BW_PASSWORD",
      "value": "${YOUR_BITWARDEN_PASSWORD}",
      "note": "Bitwarden master password (fallback unlock)",
      "id": "00000000-0000-0000-0000-000000000005",
      "projectIds": []
    },
    {
      "key": "GEMINI_API_KEY",
      "value": "${YOUR_GEMINI_API_KEY}",
      "note": "Google Gemini API key for gemini-cli",
      "id": "00000000-0000-0000-0000-000000000006",
      "projectIds": []
    },
    {
      "key": "DEEPSEEK_API_KEY",
      "value": "${YOUR_DEEPSEEK_API_KEY}",
      "note": "DeepSeek API key",
      "id": "00000000-0000-0000-0000-000000000007",
      "projectIds": []
    },
    {
      "key": "OPEN_ROUTER_API_KEY",
      "value": "${YOUR_OPEN_ROUTER_API_KEY}",
      "note": "Open Router API key for multi-provider LLM access",
      "id": "00000000-0000-0000-0000-000000000008",
      "projectIds": []
    },
    {
      "key": "GH_TOKEN",
      "value": "${YOUR_GITHUB_API_TOKEN}",
      "note": "GitHub personal access token",
      "id": "00000000-0000-0000-0000-000000000009",
      "projectIds": []
    },
    {
      "key": "NVIDIA_NIM_API_KEY",
      "value": "${YOUR_NVIDIA_API_KEY}",
      "note": "NVIDIA NIM API key",
      "id": "00000000-0000-0000-0000-00000000000a",
      "projectIds": []
    },
    {
      "key": "ANTHROPIC_AUTH_TOKEN",
      "value": "${YOUR_ANTHROPIC_API_KEY}",
      "note": "Anthropic auth token (routed via DeepSeek proxy for Claude Code)",
      "id": "00000000-0000-0000-0000-00000000000b",
      "projectIds": []
    }
  ]
}
