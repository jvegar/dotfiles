#!/usr/bin/env python3
"""
Generate waybar config + Hyprland workspace rules based on connected monitors.
Also pre-creates workspaces on assigned monitors at startup.

Split: 1 monitor → 1-6 on single bar
       2 monitors → 1-3 on left, 4-6 on right
       3 monitors → 1-2, 3-4, 5-6

Monitors are sorted left-to-right by X coordinate.
Disabled monitors (e.g., laptop lid closed) are ignored.

Usage:
  waybar-workspaces          # Full run: config + rules + restart + pre-create
  waybar-workspaces --no-create  # Skip workspace pre-creation (for post-update hook)
"""

import json
import subprocess
import sys
from pathlib import Path

OUTPUT = Path.home() / ".config/waybar/config.jsonc"
WORKSPACE_RULES = Path.home() / ".config/hypr/workspaces.conf"
HYPRLAND_CONF = Path.home() / ".config/hypr/hyprland.conf"
TOTAL_WORKSPACES = 6


def get_monitors():
    """Return connected (non-disabled) monitor names sorted left-to-right."""
    result = subprocess.run(
        ["hyprctl", "monitors", "-j"], capture_output=True, text=True
    )
    if result.returncode != 0:
        print("Failed to query monitors", file=sys.stderr)
        sys.exit(1)

    monitors = json.loads(result.stdout)
    active = [m for m in monitors if not m.get("disabled", False)]
    active.sort(key=lambda m: m.get("x", 0))
    return [m["name"] for m in active]


def distribute_workspaces(monitor_names: list[str]) -> dict[str, list[str]]:
    """Distribute 6 workspaces evenly across monitors."""
    count = len(monitor_names)
    if count <= 1:
        return {str(i): [] for i in range(1, TOTAL_WORKSPACES + 1)}

    per_monitor: list[int] = []
    base = TOTAL_WORKSPACES // count
    remainder = TOTAL_WORKSPACES % count
    for i in range(count):
        per_monitor.append(base + (1 if i < remainder else 0))

    workspaces: dict[str, list[str]] = {}
    ws = 1
    for idx, num in enumerate(per_monitor):
        for _ in range(num):
            workspaces[str(ws)] = [monitor_names[idx]]
            ws += 1
    return workspaces


def write_waybar_config(workspaces: dict[str, list[str]]):
    """Update waybar config with dynamic persistent-workspaces."""
    try:
        config = json.loads(OUTPUT.read_text())
    except (FileNotFoundError, json.JSONDecodeError) as e:
        print(f"Error reading config {OUTPUT}: {e}", file=sys.stderr)
        sys.exit(1)

    ws_module = config.setdefault("hyprland/workspaces", {})
    ws_module["all-outputs"] = False
    # Only set persistent-workspaces when all workspaces share monitors (single-monitor mode).
    # In multi-monitor mode, Hyprland's persistent:true rules handle this natively.
    if any(not monitors for monitors in workspaces.values()):
        ws_module["persistent-workspaces"] = workspaces
    elif "persistent-workspaces" in ws_module:
        del ws_module["persistent-workspaces"]

    if "format-icons" not in ws_module:
        ws_module["format-icons"] = {}
    for i in range(1, TOTAL_WORKSPACES + 1):
        ws_module["format-icons"][str(i)] = str(i)

    OUTPUT.parent.mkdir(parents=True, exist_ok=True)
    OUTPUT.write_text(json.dumps(config, indent=2) + "\n")
    print(f"Wrote waybar config → {OUTPUT}")


def write_hyprland_rules(workspaces: dict[str, list[str]]):
    """Write Hyprland workspace→monitor rules so workspaces open on the right screen."""
    lines = [
        "# Generated by waybar-workspaces — do not edit manually",
        f"# Monitors: {len(set(m for ml in workspaces.values() for m in ml) or ['all'])}",
        "",
    ]
    for ws_name, monitors in workspaces.items():
        if not monitors:
            continue  # Empty list = show on all, no rule needed
        for mon in monitors:
            lines.append(f"workspace = {ws_name}, monitor:{mon}, persistent:true")

    WORKSPACE_RULES.write_text("\n".join(lines) + "\n")
    print(f"Wrote workspace rules → {WORKSPACE_RULES}")

    # Ensure hyprland.conf sources the workspace rules
    source_line = f"source = {WORKSPACE_RULES}"
    if HYPRLAND_CONF.exists():
        content = HYPRLAND_CONF.read_text()
        if source_line not in content:
            HYPRLAND_CONF.write_text(content.rstrip() + f"\n{source_line}\n")
            print(f"Added source line to {HYPRLAND_CONF}")
            subprocess.run(["hyprctl", "reload"], check=False)
    else:
        print(f"Warning: {HYPRLAND_CONF} not found, skipping source setup", file=sys.stderr)


def pre_create_workspaces(workspaces: dict[str, list[str]]):
    """
    Create workspaces on their assigned monitors at startup.
    Temporarily switches to each workspace to materialise it, then moves it.
    """
    # Save current workspace to return to
    active = subprocess.run(
        ["hyprctl", "activeworkspace", "-j"], capture_output=True, text=True
    )
    try:
        current_ws = json.loads(active.stdout)["id"]
    except (json.JSONDecodeError, KeyError):
        current_ws = None

    commands = []
    for ws_name, monitors in workspaces.items():
        if not monitors:
            continue
        for mon in monitors:
            commands.append(f"dispatch workspace {ws_name}")
            commands.append(f"dispatch moveworkspacetomonitor {ws_name},{mon}")

    if not commands:
        print("No workspaces to pre-create (single monitor mode)")
        return

    # Return to original workspace
    if current_ws is not None:
        commands.append(f"dispatch workspace {current_ws}")

    batch = " ; ".join(commands)
    print(f"Pre-creating {len(workspaces)} workspaces...")
    subprocess.run(["hyprctl", "--batch", batch], check=False, capture_output=True)
    print("Workspace creation complete")


def main():
    create_workspaces = "--no-create" not in sys.argv

    monitor_names = get_monitors()
    if not monitor_names:
        print("No active monitors detected", file=sys.stderr)
        sys.exit(1)

    print(f"Monitors ({len(monitor_names)}): {', '.join(monitor_names)}")

    workspaces = distribute_workspaces(monitor_names)
    print(f"Layout: {workspaces}")

    write_waybar_config(workspaces)
    write_hyprland_rules(workspaces)

    subprocess.run(["omarchy", "restart", "waybar"], check=False)

    if create_workspaces:
        pre_create_workspaces(workspaces)


if __name__ == "__main__":
    main()
