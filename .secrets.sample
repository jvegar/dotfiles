# Avante Config
AVANTE_OPENAI_API_KEY=${YOUR_AVANTE_OPENAI_API_KEY}
AVANTE_MOONSHOT_API_KEY=${YOUR_MOONSHOT_API_KEY}
# Bitwarden Config
export BW_CLIENTID=${YOUR_BITWARDEN_CLIENT_ID}
export BW_CLIENTSECRET=${YOUR_BITWARDEN_CLIENT_SECRET}
export BW_PASSWORD=${YOUR_BITWARDEN_PASSWORD}
export BW_SESSION_FILE="${HOME}/.bw_session"

# Bitwarden session management
# Uses API key login (bw login --apikey) for persistent sessions without master password
# Session is cached in $BW_SESSION_FILE and automatically refreshed when expired

# Function to initialize or refresh Bitwarden session
_bw_init_session() {
	# Check if we have a valid session
	if [[ -f "$BW_SESSION_FILE" ]]; then
		local session_token="$(cat "$BW_SESSION_FILE" 2>/dev/null)"
		if [[ -n "$session_token" ]]; then
			# Test if session is still valid
			if BW_SESSION="$session_token" bw unlock --check >/dev/null 2>&1; then
				export BW_SESSION="$session_token"
				return 0
			fi
		fi
	fi

	# No valid session found, create new one using API key login
	if [[ -n "$BW_CLIENTID" && -n "$BW_CLIENTSECRET" ]]; then
		# Try API key login first (doesn't require master password)
		local new_session="$(bw login --apikey --raw 2>/dev/null)"
		if [[ -n "$new_session" ]]; then
			echo "$new_session" >"$BW_SESSION_FILE"
			chmod 600 "$BW_SESSION_FILE"
			export BW_SESSION="$new_session"
			return 0
		fi
	fi

	# Fallback to password unlock if API key login fails or credentials not set
	if [[ -n "$BW_PASSWORD" ]]; then
		local new_session="$(bw unlock --passwordenv BW_PASSWORD --raw 2>/dev/null)"
		if [[ -n "$new_session" ]]; then
			echo "$new_session" >"$BW_SESSION_FILE"
			chmod 600 "$BW_SESSION_FILE"
			export BW_SESSION="$new_session"
			return 0
		fi
	fi

	# If we get here, Bitwarden session initialization failed
	echo "Warning: Unable to initialize Bitwarden session" >&2
	return 1
}

# Initialize session on shell startup
# _bw_init_session 2>/dev/null

# Clean up function (optional)
bw_cleanup() {
	if [[ -f "$BW_SESSION_FILE" ]]; then
		rm -f "$BW_SESSION_FILE"
	fi
	unset BW_SESSION
}
#
# Gemini Cli
export GEMINI_API_KEY=${YOUR_GEMINI_API_KEY}

# Deepseek Config
export DEEPSEEK_API_KEY=${YOUR_DEEPSEEK_API_KEY}

# Open Router Config
